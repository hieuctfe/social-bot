# ============================================================
# Social Bot — Environment Variables Example
# Copy to .env and fill in your values.
# DO NOT commit real secrets.
# ============================================================

# ─── App Ports ──────────────────────────────────────────────
DASHBOARD_WEB_PORT=3000
CONTROL_API_PORT=4000
AI_WORKER_PORT=4001

# ─── Public URL ─────────────────────────────────────────────
# Set to your Tailscale/ngrok/public URL when exposing to internet.
# Leave as localhost for local-only access.
PUBLIC_URL=http://localhost:4200

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://socialbot:socialbot@postgres:5432/socialbot
POSTGRES_USER=socialbot
POSTGRES_PASSWORD=socialbot
POSTGRES_DB=socialbot

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Auth ───────────────────────────────────────────────────
JWT_SECRET=change-me-super-secret-jwt-key
JWT_EXPIRES_IN=7d
SESSION_SECRET=change-me-session-secret

# ─── Storage ────────────────────────────────────────────────
STORAGE_DRIVER=local
UPLOAD_ROOT=/data/uploads
PUBLIC_MEDIA_URL=http://localhost:4000/media

# ─── Postiz ─────────────────────────────────────────────────
POSTIZ_BASE_URL=http://postiz:3000
POSTIZ_API_URL=http://postiz:3000/api
POSTIZ_API_KEY=your-postiz-api-key-here

# ─── n8n ────────────────────────────────────────────────────
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-n8n-password
N8N_WEBHOOK_URL=http://n8n:5678
# Set to the n8n webhook URL for workflow 3 after importing (e.g. http://n8n:5678/webhook/qa-failure-alert)
N8N_QA_FAILURE_WEBHOOK_URL=
CONTROL_API_WEBHOOK_SECRET=change-me-webhook-secret
# n8n workflow env vars (passed into n8n container, read via $env.X in workflows)
GOOGLE_SHEETS_DOC_ID=
WORKSPACE_ID=
TELEGRAM_CHAT_ID=
DASHBOARD_URL=http://localhost:3000

# ─── Telegram (placeholder) ─────────────────────────────────
TELEGRAM_BOT_TOKEN=placeholder
TELEGRAM_WEBHOOK_SECRET=placeholder

# ─── AI Provider (placeholder) ──────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=placeholder
ANTHROPIC_API_KEY=placeholder

# ─── Observability ──────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
