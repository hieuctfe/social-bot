{
  "name": "social-bot",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "dev": "docker compose -f docker-compose.dev.yml up",
    "dev:api": "pnpm --filter control-api dev",
    "dev:web": "pnpm --filter dashboard-web dev",
    "dev:worker": "pnpm --filter ai-worker dev",
    "db:generate": "pnpm --filter control-api db:generate",
    "db:migrate": "pnpm --filter control-api db:migrate",
    "db:studio": "pnpm --filter control-api db:studio"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.1.4"
}
